__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
dist/
build/
*.egg-info/

# Local data/cache areas. Commit dataset cards, not large raw outputs.
data/raw/
data/processed/
data/cache/
outputs/
runs/

# Local secrets/config.
.env
.env.*
*.pem
*.key

# Large regenerable chunk-embedding caches (R15) — rebuild via data/full/embed_chunks.py
data/full/embeddings/chunks-*.npz

# Tier-2 embedding caches (R16C) — regenerable via data/tier2/finetune_tier2.py
data/tier2/embeddings/
data/tier2/*.log
# Large regenerable content chunk-embedding caches (R16A) — rebuild via data/content/embed_content.py
data/content/embeddings/

# Local numpy-only venv for this machine (Python 3.9; torch lives elsewhere)
.venv-np/
