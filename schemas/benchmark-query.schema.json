{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/crbazevedo/relational-sdlc-ai-lab/schemas/benchmark-query.schema.json",
  "title": "Benchmark Query",
  "description": "One evaluated retrieval query: a query record, a candidate pool, the relevant (positive) ids, optional hard negatives, and an optional as-of time that enables the temporal-leakage check.",
  "type": "object",
  "required": ["query_id", "task", "query_record", "candidates", "relevant"],
  "additionalProperties": false,
  "properties": {
    "query_id": { "type": "string", "minLength": 1 },
    "task": {
      "type": "string",
      "enum": [
        "issue_to_fixing_pr",
        "diff_to_affected_test",
        "log_to_likely_file",
        "pr_to_missing_test"
      ]
    },
    "query_record": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "relevant": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "hard_negatives": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "as_of": {
      "type": "string",
      "description": "ISO-8601 time of the query. Candidates/positives valid after this are leakage."
    }
  }
}
