{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/crbazevedo/relational-sdlc-ai-lab/schemas/dataset-card.schema.json",
  "title": "Dataset Card",
  "description": "Public description of a frozen dataset version: its sources, record/edge counts, relation coverage, split policy, and redistribution status.",
  "type": "object",
  "required": [
    "card_type",
    "id",
    "name",
    "version",
    "created_at",
    "sources",
    "record_counts",
    "edge_counts",
    "relation_types",
    "split_policy",
    "redistribution"
  ],
  "additionalProperties": false,
  "properties": {
    "card_type": { "const": "dataset" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "List of source-card ids that compose this dataset."
    },
    "record_counts": {
      "type": "object",
      "description": "Count of records by type.",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "edge_counts": {
      "type": "object",
      "description": "Count of edges by relation.",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "relation_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "split_policy": {
      "type": "object",
      "required": ["frozen", "method"],
      "additionalProperties": false,
      "properties": {
        "frozen": { "type": "boolean" },
        "method": {
          "type": "string",
          "description": "How splits are assigned, e.g. 'temporal-by-commit-date', 'by-repo', 'random-seeded'."
        },
        "seed": { "type": ["integer", "null"] },
        "boundary": { "type": "string", "description": "Cutoff (date/commit) for temporal splits." }
      }
    },
    "redistribution": {
      "type": "string",
      "enum": ["metadata_only", "snippets_permitted", "full_text", "synthetic_original", "mixed"]
    },
    "known_limitations": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
